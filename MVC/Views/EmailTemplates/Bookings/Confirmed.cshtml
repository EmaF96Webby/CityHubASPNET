@model CL.Models.Booking

<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>Booking Confirmation</title>
</head>

<body style="font-family: Arial, sans-serif;">

    <h2>Booking Confirmed</h2>

    <p>
        Dear @Model.Name @Model.Surname,
    </p>

    <p>
        Your booking has been successfully confirmed.
    </p>

    <h3>Booking Details</h3>

    <ul>
        <li><strong>Arrival date:</strong> @Model.ArrivalDate.ToString("dd/MM/yyyy")</li>
        <li><strong>Departure date:</strong> @Model.DepartureDate.ToString("dd/MM/yyyy")</li>
        <li><strong>Number of people:</strong> @Model.NumberOfPeople</li>
    </ul>

    <p>
        We look forward to welcoming you.
    </p>

    <p>
        Best regards,<br />
        The Staff
    </p>

</body>
</html>